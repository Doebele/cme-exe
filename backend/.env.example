# Backend environment. Copy to .env and fill in.
PORT=8093
SESSION_SECRET=generate-a-long-random-string-here

# Anthropic API key (for Hybrid mode — server pays).
# Leave blank to disable Hybrid mode (Full/visitor-key mode still works).
ANTHROPIC_API_KEY=sk-ant-...

# Admin password (bcrypt hash). Generate with:
# node -e "import('bcryptjs').then(b => console.log(b.default.hashSync('your-password', 10)));"
ADMIN_PASSWORD_HASH=$2a$10$replaceWithRealHash
