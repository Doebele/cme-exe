# Backend environment variables. Copy to .env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
SESSION_SECRET=generate-a-long-random-string-here
PORT=8093

# Admin password (bcrypt hash). Generate with:
# cd backend && node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('your-password', 10));"
ADMIN_PASSWORD_HASH=$2a$10$replaceWithRealHash
